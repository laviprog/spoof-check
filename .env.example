# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# dev | prod
ENV=prod

# Directory for storing models
MODELS_DIR=models

# Directory for uploaded files
FILES_DIR=data/files

# WEB root path
ROOT_PATH=/spoof-check

# Device to run inference on (e.g., "cpu", "cuda", "cuda:0")
DEVICE=cpu
COMPUTE_TYPE=float32

# External anti-spoofing service (optional).
# Leave ANTISPOOFING_BASE_URL unset to disable the external model — only the local model is used.
# ANTISPOOFING_USERNAME/ANTISPOOFING_PASSWORD are optional: set both to enable authentication,
# leave them unset to call the service without auth.
#ANTISPOOFING_BASE_URL=https://antispoofing-service.example.com/api
#ANTISPOOFING_USERNAME=
#ANTISPOOFING_PASSWORD=
